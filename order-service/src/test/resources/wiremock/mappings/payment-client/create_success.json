{
  "request": {
    "method": "POST",
    "url": "/api/v1/payments",
    "bodyPatterns": [
      {
        "equalToJson": "{\"orderId\": 200}",
        "ignoreExtraElements": true,
        "ignoreArrayOrder": true
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "payment-client/created_response.json"
  }
}