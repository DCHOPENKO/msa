{
  "request": {
    "method": "POST",
    "url": "/api/v1/payments",
    "bodyPatterns": [
      {
        "equalToJson": "{\"orderId\": 409}",
        "ignoreExtraElements": true,
        "ignoreArrayOrder": true
      }
    ]
  },
  "response": {
    "status": 409,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "payment-client/cached_response.json"
  }
}